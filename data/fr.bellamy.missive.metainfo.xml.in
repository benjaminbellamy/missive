<component type="desktop-application">
  <id>fr.bellamy.missive</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Missive</name>
  <summary>Run personalized email campaigns</summary>

  <description>
    <p>
      Missive sends personalized email campaigns by mail merge over SMTPS. It
      manages several sender identities, CSV recipient sheets, message
      templates, and campaigns, sending one personalized message per recipient
      at a configurable pace.
    </p>
    <p>Features:</p>
    <ul>
      <li>Multiple SMTP sender identities with credentials stored in the keyring</li>
      <li>Import recipient lists from CSV files</li>
      <li>Reusable message templates with placeholder substitution</li>
      <li>Campaign progress is saved and can be resumed after a restart</li>
    </ul>
  </description>

  <launchable type="desktop-id">fr.bellamy.missive.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/benjaminbellamy/missive/main/data/screenshots/main-window.png</image>
      <caption>The Missive main window</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/benjaminbellamy/missive</url>
  <url type="bugtracker">https://github.com/benjaminbellamy/missive/issues</url>

  <developer id="fr.bellamy">
    <name>Benjamin Bellamy</name>
  </developer>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="1.2.0" date="2026-06-27">
      <description>
        <p>Feature release.</p>
        <ul>
          <li>The message template editor is now a resizable window</li>
          <li>The unsubscribe link is configured on the template: choose a language and place an {unsubscribe} field where the link should appear in the body</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2026-06-27">
      <description>
        <p>Feature release.</p>
        <ul>
          <li>Import an HTML file as a new message template, with its CSS inlined automatically and only the page body kept</li>
          <li>Syntax highlighting in the template HTML source view, with merge fields highlighted in both the editor and the source</li>
          <li>New campaigns can append the sender identity's signature (optional) and add a localized unsubscribe link</li>
        </ul>
      </description>
    </release>
    <release version="1.0.2" date="2026-06-27">
      <description>
        <p>Maintenance release.</p>
        <ul>
          <li>Hand-edited HTML in the template source view is now kept exactly as typed, instead of being reformatted when saving or switching tabs</li>
        </ul>
      </description>
    </release>
    <release version="1.0.1" date="2026-06-26">
      <description>
        <p>Maintenance release.</p>
        <ul>
          <li>Translations are now bundled in the downloadable Flatpak, so the interface can be switched to any supported language without installing extra locale packages</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-06-16">
      <description>
        <p>First stable release.</p>
        <ul>
          <li>Manage sender identities, address sheets, message templates and mailing campaigns</li>
          <li>Personalized mail merge over SMTP with per-recipient progress and resume after restart</li>
          <li>Rich-text template editor with live preview and one-click field insertion</li>
          <li>Import CSV address sheets, including non-UTF-8 and UTF-16 files</li>
          <li>Default Cc and Bcc for new campaigns</li>
          <li>Available in English, French, German, Italian, Spanish and Dutch</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-06-15">
      <description>
        <p>Initial development release.</p>
      </description>
    </release>
  </releases>
</component>
