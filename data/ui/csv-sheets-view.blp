using Gtk 4.0;
using Adw 1;

template $MissiveCsvSheetsView: Adw.Bin {
  child: Stack view_stack {
    StackPage {
      name: "empty";

      child: Adw.StatusPage {
        icon-name: "x-office-spreadsheet-symbolic";
        title: _("No CSV Sheets");
        description: _("Import a CSV file of recipients to use in a campaign.");
      };
    }

    StackPage {
      name: "list";

      child: ScrolledWindow {
        hscrollbar-policy: never;

        child: Adw.Clamp {
          maximum-size: 700;
          margin-top: 24;
          margin-bottom: 24;
          margin-start: 12;
          margin-end: 12;

          child: ListBox sheet_list {
            selection-mode: none;
            valign: start;

            styles [
              "boxed-list",
            ]
          };
        };
      };
    }
  };
}
