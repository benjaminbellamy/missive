msgid "Sending a Campaign"
msgstr "Sending a Campaign"

msgid "Missive sends one personalized email per recipient through your own SMTP server, at a pace you choose."
msgstr "Missive sends one personalized email per recipient through your own SMTP server, at a pace you choose."

msgid "1. Add a sender identity"
msgstr "1. Add a sender identity"

msgid "In Sender Identities, click New and enter your SMTP server and login. The Connection row confirms the settings work."
msgstr "In Sender Identities, click New and enter your SMTP server and login. The Connection row confirms the settings work."

msgid "2. Import an address sheet"
msgstr "2. Import an address sheet"

msgid "In Address Sheets, click Import and choose a CSV file, then pick the column that holds the email addresses."
msgstr "In Address Sheets, click Import and choose a CSV file, then pick the column that holds the email addresses."

msgid "3. Write a message template"
msgstr "3. Write a message template"

msgid "In Message Templates, click New. Add a subject and body, and use “Insert Fields From” to drop {tokens} that are replaced for each recipient."
msgstr "In Message Templates, click New. Add a subject and body, and use “Insert Fields From” to drop {tokens} that are replaced for each recipient."

msgid "4. Create a mailing campaign"
msgstr "4. Create a mailing campaign"

msgid "In Mailing Campaigns, click New Campaign and choose an identity, address sheet, template and recipient column."
msgstr "In Mailing Campaigns, click New Campaign and choose an identity, address sheet, template and recipient column."

msgid "5. Test, then send"
msgstr "5. Test, then send"

msgid "Open the campaign, click Send Test to check it, then Run. Progress is saved, so you can pause, stop and continue at any time."
msgstr "Open the campaign, click Send Test to check it, then Run. Progress is saved, so you can pause, stop and continue at any time."

