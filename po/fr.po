msgid "Write {column_name} in the subject or body to insert a recipient's value. Use {{ and }} for literal braces."
msgstr "Écrivez {nom_de_colonne} dans l’objet ou le corps pour insérer la valeur d’un destinataire. Utilisez {{ et }} pour des accolades littérales."

msgid "Privacy"
